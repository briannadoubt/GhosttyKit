framework module CGhosttyKitBinary {
    umbrella header "ghostty.h"
    exclude header "ghostty/vt.h"
    exclude header "ghostty/vt/allocator.h"
    exclude header "ghostty/vt/build_info.h"
    exclude header "ghostty/vt/color.h"
    exclude header "ghostty/vt/device.h"
    exclude header "ghostty/vt/focus.h"
    exclude header "ghostty/vt/formatter.h"
    exclude header "ghostty/vt/grid_ref.h"
    exclude header "ghostty/vt/key.h"
    exclude header "ghostty/vt/key/encoder.h"
    exclude header "ghostty/vt/key/event.h"
    exclude header "ghostty/vt/modes.h"
    exclude header "ghostty/vt/mouse.h"
    exclude header "ghostty/vt/mouse/encoder.h"
    exclude header "ghostty/vt/mouse/event.h"
    exclude header "ghostty/vt/osc.h"
    exclude header "ghostty/vt/paste.h"
    exclude header "ghostty/vt/point.h"
    exclude header "ghostty/vt/render.h"
    exclude header "ghostty/vt/screen.h"
    exclude header "ghostty/vt/sgr.h"
    exclude header "ghostty/vt/size_report.h"
    exclude header "ghostty/vt/style.h"
    exclude header "ghostty/vt/terminal.h"
    exclude header "ghostty/vt/types.h"
    exclude header "ghostty/vt/wasm.h"
    export *
    module * { export * }
}
